# Clé API TMDB (gratuite sur https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your_tmdb_api_key_here

# URL d'une instance Consumet self-hostée (pour le lecteur HD natif sans pub)
# Voir README → "Déployer Consumet" pour l'installation gratuite sur Render
# Si vide, le site bascule automatiquement sur les serveurs iframe
CONSUMET_BASE_URL=

# Port du serveur (optionnel, défaut: 3000)
PORT=3000
